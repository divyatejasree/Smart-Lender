{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Smart Lender Flask App",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "FLASK_ENV": "development"
      }
    },
    {
      "name": "Train Smart Lender Model",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/train_model.py",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
